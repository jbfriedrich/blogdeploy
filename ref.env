# Template for the resolved SMTP env. Do NOT inject this file directly — copy it to
# ref.local.env (gitignored), put your real 1Password refs + SMTP host/from there, then:
#   op inject -i ref.local.env -o /tmp/blogdeploy.env
# Keep 1Password-reference tokens out of comment lines: op inject resolves references
# everywhere in the file, comments included, and a malformed one aborts the run.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=op://Vault/smtp/username
SMTP_PASSWORD=op://Vault/smtp/password
SMTP_FROM=deploy@example.com
SMTP_TO=op://Vault/blogdeploy/notify-to
NOTIFY_ON_SUCCESS=false
