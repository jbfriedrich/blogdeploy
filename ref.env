# op inject -i ref.env -o .env  (run on the WORKSTATION; place .env at /etc/blogdeploy/.env on the VM)
# Adjust the op:// vault/item names and the SMTP host/from to your own setup before injecting.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=op://Vault/smtp/username
SMTP_PASSWORD=op://Vault/smtp/password
SMTP_FROM=deploy@example.com
SMTP_TO=op://Vault/blogdeploy/notify-to
NOTIFY_ON_SUCCESS=false
